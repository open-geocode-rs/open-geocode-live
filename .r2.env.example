# R2 S3 credentials for the basemap upload. Copy to .r2.env (gitignored) and fill in.
#
# Get the keys in the Cloudflare dashboard: R2 -> Manage R2 API Tokens -> Create
# API Token (Object Read & Write). The account ID is your R2 endpoint subdomain,
# or run `wrangler whoami`.

R2_ACCESS_KEY_ID="<access key id>"
R2_SECRET_ACCESS_KEY="<secret access key>"
R2_ACCOUNT_ID="<account id>"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET="open-geocode"
