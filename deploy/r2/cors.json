{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://example.com",
          "http://localhost:8787",
          "http://127.0.0.1:8787"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["range", "if-match", "if-none-match"]
      },
      "exposeHeaders": ["Content-Length", "Content-Range", "Accept-Ranges", "ETag"],
      "maxAgeSeconds": 86400
    }
  ]
}
